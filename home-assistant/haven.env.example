# Copy to .env.home-assistant at the repository root. Never commit the real file.
TZ=America/New_York
HAVEN_HOST=haven.home.arpa
HAVEN_PROXY_KEY=replace-with-output-from-openssl-rand-hex-32
ALLOW_SENSITIVE_ACTIONS=false

# This file must contain only the Home Assistant long-lived access token.
HA_TOKEN_FILE=./home-assistant/secrets/haven_gateway_token

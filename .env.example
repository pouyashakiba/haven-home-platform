# The gateway never silently changes from live Home Assistant data to demo data.
AUTOMATION_MODE=demo
HAVEN_HOST=haven.home.arpa
HAVEN_PROXY_KEY=replace-with-a-long-random-value
ALLOW_SENSITIVE_ACTIONS=false

# Required only when AUTOMATION_MODE=live.
HA_URL=http://host.docker.internal:8123
HA_TOKEN=
